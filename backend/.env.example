# ── AWS credentials ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# ── Amazon Bedrock ───────────────────────────────────────────────────────────
# Enable Claude 3 Haiku in AWS Console → Bedrock → Model access
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ── Amazon Polly ─────────────────────────────────────────────────────────────
# Neutral / neural voices: Matthew, Joanna, Lupe, Amy
POLLY_VOICE_ID=Matthew

# ── Amazon S3 ────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=your-ai-tutor-bucket
S3_AVATAR_KEY=avatar/teacher.glb

# ── Supabase (progress tracking — optional) ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Legacy (not used with AWS) ───────────────────────────────────────────────
GROQ_API_KEY=
